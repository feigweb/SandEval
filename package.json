{
  "name": "sandeval",
  "version": "0.1.0",
  "description": "CLI/TUI sandbox evaluator for coding agents and model arenas.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "sandeval": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
